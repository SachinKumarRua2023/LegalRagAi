# ============================================================
# CompleteRagAI — Environment Variables
# Copy this file to .env and fill in your API keys
# You only need ONE of the three LLM keys below.
# ============================================================

# ── LLM Provider ─────────────────────────────────────────────
# "groq" = Force Groq only (recommended)
# "auto" = picks first available: Groq → Gemini → Claude
LLM_PROVIDER=groq

# ── Option 1: Groq (FREE, fastest — RECOMMENDED) ─────────────
# Free tier: 30 RPM, 14,400 req/day, Llama 3.3 70B
# Get key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Option 2: Google Gemini (FREE) ────────────────────────────
# Uncomment below to use Gemini instead of Groq
# Free tier: 15 RPM, 1M tokens/day
# Get key: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_MODEL=gemini-1.5-flash

# ── Option 3: Anthropic Claude ────────────────────────────────
# Uncomment below to use Claude
# Get key: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Embeddings ────────────────────────────────────────────────
# "local"  = sentence-transformers (free, no API, runs on CPU)
# "google" = text-embedding-004 (free, requires GOOGLE_API_KEY)
EMBEDDING_MODEL=local

# ── Vector DB ─────────────────────────────────────────────────
# "chromadb" = Local SQLite (default, for local dev)
# "pinecone" = Cloud serverless (for Vercel/Render deployment)
VECTOR_DB_PROVIDER=chromadb

# ChromaDB (local — free, for local development)
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=legal_cases

# Pinecone (cloud — REQUIRED for Vercel/Render deployment)
# Free tier: 2GB storage, 100k vectors
# Get API key: https://app.pinecone.io
# PINECONE_API_KEY=your_pinecone_api_key_here
# PINECONE_INDEX_NAME=legal-rag
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1

# ── Data Paths ─────────────────────────────────────────────────
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed
DATA_UPLOADS_PATH=./data/uploads

# ── CourtListener API (FREE — optional for higher rate limits) ─
# Register free: https://www.courtlistener.com/sign-in/
COURTLISTENER_TOKEN=

# ── Backend server port ────────────────────────────────────────
PORT=8000
